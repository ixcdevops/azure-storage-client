# Azure Storage Account credentials (optional – can also be entered via the web UI)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=

# Path inside the container where downloaded files are stored (must match the volume mount)
DOWNLOAD_PATH=/data

# Flask secret key – set a strong random value in production
SECRET_KEY=change-me-to-a-random-secret

# OneDrive / Microsoft Graph OAuth
# Register an app at https://portal.azure.com → App Registrations (personal accounts / consumers)
# Redirect URI to register: http://localhost:8080/onedrive/callback
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_REDIRECT_URI=http://localhost:8080/onedrive/callback
